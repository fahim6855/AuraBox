{
  "name": "Devcontainer",
  "image": "ghcr.io/codesandbox/devcontainers/typescript-node:latest",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "dash",
        "terminal.integrated.profiles.linux": {
          "dash": {
            "path": "/bin/dash"
          }
        }
      }
    }
  },
  "remoteUser": "node"
}
